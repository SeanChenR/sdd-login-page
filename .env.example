# Better Auth
BETTER_AUTH_SECRET=your-secret-here-32-chars-minimum

# Email: use Mailpit locally (set SMTP_HOST=localhost SMTP_PORT=1025)
# or leave SMTP_HOST unset to use Resend in production
SMTP_HOST=localhost
SMTP_PORT=1025
RESEND_FROM_EMAIL=noreply@local.dev

# Resend (production only, when SMTP_HOST is not set)
RESEND_API_KEY=re_your_api_key_here

# App URL (used by better-auth for callback URLs)
BETTER_AUTH_URL=http://localhost:3000
